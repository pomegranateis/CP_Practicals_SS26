# .gitignore for CP_Practicals_SS26
# Ignore compiled binaries, generated outputs, and runtime artifacts

# Compiled objects and executables
*.o
*.exe
a.out

# Common compiled-output files
*.out

# Problem executables (common naming used in this repo)
Problem*

# Per-problem output files and output folders (do not commit generated outputs)
**/output.txt
**/outputs/
**/*_output.txt
**/*.output.txt

# Editor/OS artifacts
.DS_Store
Thumbs.db

# NOTE:
# These files are machine-generated artifacts (binaries and runtime outputs).
# They should not be committed because they are large or platform-dependent,
# clutter the repository history, and are reproducible from source + inputs.
